{
  "name": "oat-docs",
  "version": "0.1.0",
  "private": true,
  "description": "MkDocs Material documentation for Open Agent Toolkit.",
  "type": "module",
  "scripts": {
    "docs:dev": "mkdocs serve",
    "docs:build": "mkdocs build",
    "docs:setup": "sh ./setup-docs.sh",
    "docs:lint": "echo 'docs lint disabled'",
    "docs:format": "oxfmt 'docs/**/*.md'",
    "docs:format:check": "oxfmt --check 'docs/**/*.md'"
  },
  "devDependencies": {
    "oxfmt": "^0.36.0"
  }
}
