{
  "name": "@open-agent-toolkit/cli",
  "version": "0.0.24",
  "private": false,
  "description": "Open Agent Toolkit CLI",
  "homepage": "https://github.com/voxmedia/open-agent-toolkit/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/voxmedia/open-agent-toolkit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voxmedia/open-agent-toolkit.git",
    "directory": "packages/cli"
  },
  "bin": {
    "oat": "dist/index.js"
  },
  "files": [
    "dist",
    "assets",
    "README.md"
  ],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "bash scripts/bundle-assets.sh && tsc && tsc-alias",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "check": "oxlint . && oxfmt --check .",
    "check:fix": "oxlint --fix . && oxfmt .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@iarna/toml": "2.2.5",
    "@inquirer/prompts": "^8.2.0",
    "@open-agent-toolkit/control-plane": "workspace:*",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "ora": "^9.0.0",
    "yaml": "2.8.2",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.17.0"
  }
}
