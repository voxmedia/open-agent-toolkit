{
  "name": "@oat/cli",
  "version": "0.0.1",
  "description": "Open Agent Toolkit CLI",
  "type": "module",
  "private": true,
  "bin": {
    "oat": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "chalk": "^5.6.2",
    "commander": "^12.1.0",
    "dotenv": "^17.2.3",
    "gray-matter": "^4.0.3",
    "ora": "^9.0.0",
    "yaml": "^2.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=22.17.0"
  }
}
