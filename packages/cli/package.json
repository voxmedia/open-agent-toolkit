{
  "name": "@oat/cli",
  "version": "0.0.1",
  "description": "Open Agent Toolkit CLI",
  "type": "module",
  "private": true,
  "bin": {
    "oat": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && tsc-alias",
    "clean": "rm -rf dist",
    "dev": "tsx watch src/index.ts",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "type-check": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=22.17.0"
  }
}
