{
  "name": "@open-agent-toolkit/docs-theme",
  "version": "0.0.25",
  "private": false,
  "description": "Theme components for OAT documentation sites",
  "homepage": "https://github.com/voxmedia/open-agent-toolkit/tree/main/packages/docs-theme",
  "bugs": {
    "url": "https://github.com/voxmedia/open-agent-toolkit/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/voxmedia/open-agent-toolkit.git",
    "directory": "packages/docs-theme"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "check": "oxlint . && oxfmt --check .",
    "check:fix": "oxlint --fix . && oxfmt .",
    "format": "oxfmt --check .",
    "format:fix": "oxfmt .",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "mermaid": "^11.6.0",
    "next-themes": "^0.4.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "fumadocs-core": "^16.6.13",
    "fumadocs-ui": "^16.6.13",
    "next": "^16.1.6",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typescript": "^5.8.3"
  },
  "peerDependencies": {
    "fumadocs-core": ">=16.0.0",
    "fumadocs-ui": ">=16.0.0",
    "next": ">=16.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0"
  },
  "engines": {
    "node": ">=22.17.0"
  }
}
