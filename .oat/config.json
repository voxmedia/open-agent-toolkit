{
  "version": 1,
  "worktrees": {
    "root": ".worktrees"
  },
  "projects": {
    "root": ".oat/projects/shared"
  },
  "documentation": {
    "root": "apps/oat-docs/docs",
    "tooling": "mkdocs",
    "config": "apps/oat-docs/mkdocs.yml",
    "requireForProjectCompletion": false
  },
  "localPaths": [
    ".oat/ideas",
    ".oat/projects/**/pr",
    ".oat/projects/**/reviews",
    ".oat/projects/archived",
    ".oat/projects/local"
  ]
}
