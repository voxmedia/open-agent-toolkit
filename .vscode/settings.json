{
  "editor.defaultFormatter": "oxc.oxc-vscode",
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.oxc": "explicit"
  },
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[markdown]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "search.exclude": {
    "**/.turbo/": true,
    "**/node_modules": true,
    "**/dist": true,
    "**/tsconfig.tsbuildinfo": true
  },
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true
  },
  "files.associations": {
    "turbo.json": "jsonc",
    "tsconfig.json": "jsonc",
    "*.config.json": "jsonc"
  },
  "claudeCode.respectGitIgnore": false
}
